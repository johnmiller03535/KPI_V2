# Redmine
REDMINE_URL=https://kkp.rm.mosreg.ru
REDMINE_API_KEY=your_api_key_here

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=kpi_portal
POSTGRES_USER=kpi_user
POSTGRES_PASSWORD=change_me_in_production

# JWT
JWT_SECRET_KEY=change_me_in_production_min_32_chars_xxxxxxxxxx
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
# chat_id финансового блока (через запятую, напр. 123456,654321)
FINANCE_TELEGRAM_IDS=

# AI — GigaChat (основной)
# base64(client_id:client_secret) из developers.sber.ru/gigachat
GIGACHAT_API_KEY=

# AI — YandexGPT (резервный)
# Ключ из console.yandex.cloud → Сервисные аккаунты → API-ключи
YANDEX_API_KEY=AQVN...
# ID каталога в Yandex Cloud (console.yandex.cloud → Каталог → Обзор)
YANDEX_FOLDER_ID=b1g...

# App
APP_ENV=development

# CORS: список origin через запятую
# Локально через nginx: http://localhost,http://localhost:3000
# Продакшн (Amvera): https://your-app.amvera.io
FRONTEND_URL=http://localhost,http://localhost:3000

# URL бэкенда (используется в ссылках из PDF/TG)
BACKEND_URL=http://localhost:8000
